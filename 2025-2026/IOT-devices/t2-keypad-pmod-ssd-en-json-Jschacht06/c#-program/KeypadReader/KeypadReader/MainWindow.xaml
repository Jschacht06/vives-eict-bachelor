<Window x:Class="KeypadReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Keypad Reader" Height="350" Width="300">
    <StackPanel Margin="20">
        <TextBlock Text="COM Port:"/>
        <ComboBox x:Name="cmbComPorts" Height="25" Margin="0,5,0,10"/>

        <Button x:Name="btnConnect" Content="Connect" Click="BtnConnect_Click" Height="30" Margin="0,0,0,10"/>
        <Button x:Name="btnDisconnect" Content="Disconnect" Click="BtnDisconnect_Click" Height="30" Margin="0,0,0,20" IsEnabled="False"/>

        <TextBlock Text="Last Key Pressed:" FontWeight="Bold" HorizontalAlignment="Center"/>
        <Border BorderBrush="Black" BorderThickness="2" Background="LightYellow" Margin="0,10" Padding="20">
            <TextBlock x:Name="tbKey" Text="No key" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </StackPanel>
</Window>