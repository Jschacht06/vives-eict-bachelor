<Window x:Class="sensor_history_plot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:sensor_history_plot"
        mc:Ignorable="d"
        Title="Sensor History Plot" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Button x:Name="Start_recording"
                Content="Start"
                Width="100"
                Height="25"
                Margin="10"
                Click="Start_recording_Click"
                Grid.Row="0" />
        
        <Canvas x:Name="canvas"
                Background="White"
                Grid.Row="1"
                Margin="10" />
    </Grid>
</Window>
